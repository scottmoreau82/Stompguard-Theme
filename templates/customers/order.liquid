{% section 'section-nav' %}
<main style="padding:7rem 2rem 4rem;max-width:800px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-head);font-size:2rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--chrome-hi);margin-bottom:1rem;">Order {{ order.name }}</h1>
  <p style="font-family:var(--font-mono);font-size:0.8rem;color:var(--muted);margin-bottom:2rem;">{{ order.created_at | date: '%B %d, %Y' }}</p>
  {% for line in order.line_items %}
    <div style="display:flex;justify-content:space-between;padding:1rem;background:var(--surface);border:1px solid rgba(200,200,200,0.06);margin-bottom:0.5rem;font-family:var(--font-mono);font-size:0.8rem;color:var(--text);">
      <span>{{ line.title }} &times; {{ line.quantity }}</span><span>{{ line.final_line_price | money }}</span>
    </div>
  {% endfor %}
  <div style="display:flex;justify-content:space-between;margin-top:1rem;font-family:var(--font-mono);font-size:1.1rem;color:var(--chrome-hi);"><span>Total</span><span>{{ order.total_price | money }}</span></div>
</main>
{% section 'section-footer' %}
