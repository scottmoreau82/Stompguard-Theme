{% section 'section-nav' %}
<main style="padding:7rem 2rem 4rem;max-width:440px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-head);font-size:2rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--chrome-hi);margin-bottom:1.5rem;">Login</h1>
  {% form 'customer_login' %}
    {{ form.errors | default_errors }}
    <input type="email" name="customer[email]" placeholder="Email" required style="background:var(--surface2);border:1px solid var(--gunmetal);color:var(--text);font-family:var(--font-mono);font-size:0.8rem;padding:12px;width:100%;margin-bottom:1rem;"/>
    <input type="password" name="customer[password]" placeholder="Password" style="background:var(--surface2);border:1px solid var(--gunmetal);color:var(--text);font-family:var(--font-mono);font-size:0.8rem;padding:12px;width:100%;margin-bottom:1rem;"/>
    <button type="submit" style="width:100%;background:var(--red);color:var(--chrome-hi);font-family:var(--font-mono);font-size:0.78rem;letter-spacing:0.2em;text-transform:uppercase;padding:14px;border:1px solid var(--red-hi);cursor:pointer;">Sign In</button>
  {% endform %}
  <p style="margin-top:1.5rem;font-family:var(--font-mono);font-size:0.75rem;color:var(--muted);"><a href="{{ routes.account_register_url }}" style="color:var(--chrome-lo);">Create account &rarr;</a></p>
</main>
{% section 'section-footer' %}
