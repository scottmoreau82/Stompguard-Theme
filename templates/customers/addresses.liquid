{% section 'section-nav' %}
<main style="padding:7rem 2rem 4rem;max-width:800px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-head);font-size:2rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--chrome-hi);margin-bottom:2rem;">Addresses</h1>
  {% for address in customer.addresses %}
    <div style="padding:1rem;background:var(--surface);border:1px solid rgba(200,200,200,0.06);margin-bottom:1rem;font-family:var(--font-mono);font-size:0.8rem;color:var(--text);line-height:1.6;">
      {{ address.first_name }} {{ address.last_name }}<br>{{ address.address1 }}<br>{{ address.city }}, {{ address.province }} {{ address.zip }}<br>{{ address.country }}
    </div>
  {% endfor %}
</main>
{% section 'section-footer' %}
