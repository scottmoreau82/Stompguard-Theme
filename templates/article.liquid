{% section 'section-nav' %}
<main style="padding:7rem 2rem 4rem;max-width:760px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-head);font-size:2.4rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--chrome-hi);margin-bottom:1rem;">{{ article.title }}</h1>
  <div style="font-family:var(--font-mono);font-size:0.72rem;color:var(--muted);margin-bottom:2rem;">{{ article.published_at | date: '%B %d, %Y' }}</div>
  <div style="font-family:var(--font-body);font-weight:300;font-size:0.95rem;color:var(--text);line-height:1.8;">{{ article.content }}</div>
</main>
{% section 'section-footer' %}
