{% comment %} StompGuard — Contact Page Template {% endcomment %}

{% section 'section-nav' %}

<style>
  #sg-contact {
    padding: 7rem 2rem 4rem;
    max-width: 720px;
    margin: 0 auto;
    min-height: 60vh;
  }
  #sg-contact .contact-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  #sg-contact .contact-eyebrow::before { content: '// '; color: var(--chrome-lo); }
  #sg-contact h1 {
    font-family: var(--font-head);
    font-size: 2.4rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--chrome-hi);
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  #sg-contact .contact-intro {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  #sg-contact .contact-intro a { color: var(--red); text-decoration: none; }
  #sg-contact .contact-intro a:hover { color: var(--red-hi); }
  #sg-contact .contact-field { margin-bottom: 1.25rem; }
  #sg-contact .contact-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--chrome-lo);
    margin-bottom: 0.5rem;
  }
  #sg-contact .contact-input,
  #sg-contact .contact-textarea {
    width: 100%;
    background: var(--black);
    border: 1px solid var(--gunmetal);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
    clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 0 100%);
  }
  #sg-contact .contact-textarea { min-height: 160px; resize: vertical; line-height: 1.6; }
  #sg-contact .contact-input:focus,
  #sg-contact .contact-textarea:focus { border-color: var(--red); }
  #sg-contact .contact-input::placeholder,
  #sg-contact .contact-textarea::placeholder { color: var(--muted); }
  #sg-contact .contact-btn {
    background: var(--red);
    color: var(--chrome-hi);
    border: 1px solid var(--red-hi);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 16px 32px;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 0.5rem;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }
  #sg-contact .contact-btn:hover { background: var(--red-hi); }
  #sg-contact .contact-msg {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    padding: 14px 18px;
    margin-bottom: 2rem;
    border: 1px solid;
  }
  #sg-contact .contact-msg.ok { color: #2ecc71; border-color: rgba(46,204,113,0.4); background: rgba(46,204,113,0.06); }
  #sg-contact .contact-msg.err { color: #e74c3c; border-color: rgba(231,76,60,0.4); background: rgba(231,76,60,0.06); }
  @media (max-width: 768px) {
    #sg-contact { padding: 6rem 1.25rem 3rem; }
    #sg-contact h1 { font-size: 1.9rem; }
  }
</style>

<main id="sg-contact">
  <div class="contact-eyebrow">{{ page.title | default: 'Get In Touch' }}</div>
  <h1>{{ page.title }}</h1>

  {%- if page.content != blank -%}
    <div class="contact-intro">{{ page.content }}</div>
  {%- endif -%}

  {%- form 'contact', id: 'sg-contact-form' -%}
    {%- if form.posted_successfully? -%}
      <div class="contact-msg ok">Message received. We'll get back to you shortly.</div>
    {%- elsif form.errors -%}
      <div class="contact-msg err">{{ form.errors | default_errors }}</div>
    {%- endif -%}

    <div class="contact-field">
      <label class="contact-label" for="contact-name">Name</label>
      <input type="text" id="contact-name" class="contact-input" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Your name" required>
    </div>

    <div class="contact-field">
      <label class="contact-label" for="contact-email">Email</label>
      <input type="email" id="contact-email" class="contact-input" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="your@email.com" required>
    </div>

    <div class="contact-field">
      <label class="contact-label" for="contact-subject">Subject</label>
      <input type="text" id="contact-subject" class="contact-input" name="contact[subject]" value="{{ form.subject }}" placeholder="What's this about?">
    </div>

    <div class="contact-field">
      <label class="contact-label" for="contact-body">Message</label>
      <textarea id="contact-body" class="contact-textarea" name="contact[body]" placeholder="Tell us what you need." required>{{ form.body }}</textarea>
    </div>

    <button type="submit" class="contact-btn">Send Message &rarr;</button>
  {%- endform -%}
</main>

{% section 'section-footer' %}
