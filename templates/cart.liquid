{% section 'section-nav' %}

<main style="padding:7rem 2rem 4rem;max-width:900px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-head);font-size:2.4rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--chrome-hi);margin-bottom:2rem;">Cart</h1>

  {% if cart.item_count > 0 %}
    {% form 'cart', cart %}
      {% for item in cart.items %}
        <div style="display:flex;gap:1.5rem;padding:1.5rem;background:var(--surface);border:1px solid rgba(200,200,200,0.06);margin-bottom:1rem;align-items:center;">
          <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}" style="width:80px;height:80px;object-fit:cover;border:1px solid var(--gunmetal);"/>
          <div style="flex:1;">
            <div style="font-family:var(--font-head);font-size:1rem;letter-spacing:0.05em;text-transform:uppercase;color:var(--chrome-hi);">{{ item.product.title }}</div>
            <div style="font-family:var(--font-mono);font-size:0.85rem;color:var(--chrome);margin-top:4px;">{{ item.final_price | money }}</div>
          </div>
          <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:60px;background:var(--surface2);border:1px solid var(--gunmetal);color:var(--text);font-family:var(--font-mono);padding:8px;text-align:center;"/>
        </div>
      {% endfor %}

      <div style="display:flex;justify-content:space-between;align-items:center;margin:2rem 0;padding-top:1.5rem;border-top:1px solid rgba(200,200,200,0.1);">
        <span style="font-family:var(--font-mono);font-size:0.9rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);">Subtotal</span>
        <span style="font-family:var(--font-mono);font-size:1.5rem;color:var(--chrome-hi);">{{ cart.total_price | money }}</span>
      </div>

      <div style="display:flex;gap:1rem;">
        <button type="submit" name="update" style="flex:1;background:transparent;border:1px solid var(--gunmetal);color:var(--chrome-lo);font-family:var(--font-mono);font-size:0.78rem;letter-spacing:0.15em;text-transform:uppercase;padding:16px;cursor:pointer;">Update</button>
        <button type="submit" name="checkout" style="flex:2;background:var(--red);color:var(--chrome-hi);font-family:var(--font-mono);font-size:0.78rem;letter-spacing:0.2em;text-transform:uppercase;padding:16px;border:1px solid var(--red-hi);cursor:pointer;clip-path:polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));">Checkout &rarr;</button>
      </div>
    {% endform %}
  {% else %}
    <p style="font-family:var(--font-mono);font-size:0.9rem;color:var(--muted);letter-spacing:0.1em;">Your cart is empty. <a href="{{ routes.root_url }}" style="color:var(--red);">Continue shopping &rarr;</a></p>
  {% endif %}
</main>

{% section 'section-footer' %}
