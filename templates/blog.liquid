{% section 'section-nav' %}
<main style="padding:7rem 2rem 4rem;max-width:900px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-head);font-size:2.4rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--chrome-hi);margin-bottom:2rem;">{{ blog.title }}</h1>
  {% for article in blog.articles %}
    <a href="{{ article.url }}" style="display:block;margin-bottom:1.5rem;font-family:var(--font-head);font-size:1.2rem;letter-spacing:0.04em;text-transform:uppercase;color:var(--chrome-hi);">{{ article.title }}</a>
  {% endfor %}
</main>
{% section 'section-footer' %}
