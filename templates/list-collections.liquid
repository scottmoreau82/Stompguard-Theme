{% section 'section-nav' %}
<main style="padding:7rem 2rem 4rem;max-width:1100px;margin:0 auto;min-height:60vh;">
  <h1 style="font-family:var(--font-head);font-size:2.4rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--chrome-hi);margin-bottom:2rem;">Collections</h1>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">
    {% for collection in collections %}
      <a href="{{ collection.url }}" style="background:var(--surface);border:1px solid rgba(200,200,200,0.06);padding:2rem;font-family:var(--font-head);font-size:1.1rem;letter-spacing:0.05em;text-transform:uppercase;color:var(--chrome-hi);">{{ collection.title }}</a>
    {% endfor %}
  </div>
</main>
{% section 'section-footer' %}
