{% section 'section-nav' %}

<main style="padding:7rem 2rem 4rem;max-width:1200px;margin:0 auto;min-height:60vh;">
  <div style="font-family:var(--font-mono);font-size:0.76rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--red);margin-bottom:0.8rem;">// {{ collection.title }}</div>
  <h1 style="font-family:var(--font-head);font-size:clamp(2.5rem,5vw,4rem);letter-spacing:0.04em;text-transform:uppercase;color:var(--chrome-hi);line-height:0.95;margin-bottom:3rem;">{{ collection.title }}</h1>

  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;">
    {% for product in collection.products %}
      <a href="{{ product.url }}" style="background:var(--surface);border:1px solid rgba(200,200,200,0.05);clip-path:polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));display:block;">
        <div style="aspect-ratio:1;overflow:hidden;background:var(--surface2);">
          <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;opacity:0.85;filter:contrast(1.1) saturate(0.75);"/>
        </div>
        <div style="padding:1.2rem;border-top:1px solid rgba(200,200,200,0.05);">
          <div style="font-family:var(--font-head);font-size:0.95rem;letter-spacing:0.04em;text-transform:uppercase;color:var(--chrome-hi);line-height:1.2;margin-bottom:0.6rem;">{{ product.title }}</div>
          <div style="font-family:var(--font-mono);font-size:1.1rem;color:var(--chrome);">{{ product.price | money }}</div>
        </div>
      </a>
    {% endfor %}
  </div>
</main>

{% section 'section-footer' %}

<style>
  @media (max-width:1024px){ main > div:last-of-type { grid-template-columns:repeat(2,1fr) !important; } }
  @media (max-width:600px){ main > div:last-of-type { grid-template-columns:1fr !important; } }
</style>
