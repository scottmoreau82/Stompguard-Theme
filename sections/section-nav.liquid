{% comment %} StompGuard — Nav Section {% endcomment %}

<style>
  #sg-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2.5rem;
    background: rgba(8,8,8,0.95);
    border-bottom: 1px solid rgba(200,200,200,0.08);
    backdrop-filter: blur(8px);
  }
  #sg-nav::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--chrome), var(--red), var(--chrome), transparent);
  }
  #sg-nav .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; flex-shrink: 0; }
  #sg-nav .nav-logo img { height: 36px; width: auto; }
  #sg-nav .nav-wordmark {
    font-family: var(--font-head);
    font-size: 1.6rem;
    letter-spacing: 0.15em;
    color: var(--chrome-hi);
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
  #sg-nav .nav-wordmark span {
    color: var(--chrome-lo);
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    display: block;
    margin-top: -6px;
    font-family: var(--font-mono);
  }
  #sg-nav .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  #sg-nav .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--chrome-lo);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }
  #sg-nav .nav-links a::before { content: '//'; margin-right: 4px; color: var(--red); opacity: 0.6; }
  #sg-nav .nav-links a:hover { color: var(--chrome-hi); }
  #sg-nav .nav-cta {
    background: var(--red);
    color: var(--chrome-hi);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 8px 18px;
    border: 1px solid var(--red-hi);
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    transition: background 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    flex-shrink: 0;
  }
  #sg-nav .nav-cta:hover { background: var(--red-hi); }
  #sg-nav .nav-cta-count {
    background: var(--chrome-hi);
    color: var(--red);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    width: 18px; height: 18px;
    border-radius: 50%;
    display: inline-block;
    line-height: 18px;
    text-align: center;
    vertical-align: middle;
    padding: 0;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    #sg-nav .nav-links { display: none; }
    #sg-nav { padding: 0 1rem; }
  }
</style>

<nav id="sg-nav">
  <a href="{{ routes.root_url }}" class="nav-logo">
    {% if section.settings.logo != blank %}
      <img src="{{ section.settings.logo | image_url: width: 72 }}" alt="{{ shop.name }} Logo"/>
    {% else %}
      <img src="{{ 'RoboLogoSVGfinal.png' | asset_url }}" alt="{{ shop.name }} Logo"/>
    {% endif %}
    <div class="nav-wordmark">
      {{ section.settings.wordmark }}
      <span>{{ section.settings.tagline }}</span>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="{{ routes.root_url }}">Home</a></li>
    <li><a href="{{ routes.all_products_collection_url }}">Catalog</a></li>
    <li><a href="{{ routes.root_url }}#sg-products-section">Acrylic Covers</a></li>
    <li><a href="{{ pages[section.settings.contact_page].url | default: pages['contact-page'].url }}">Contact</a></li>
  </ul>
  <button class="nav-cta" onclick="if(typeof sgOpenCart==='function'){sgOpenCart()}else{window.location.href='{{ routes.cart_url }}'}">
    Cart <span class="nav-cta-count" id="sg-cart-count">{{ cart.item_count }}</span>
  </button>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    fetch('{{ routes.cart_url }}.js')
      .then(function(r){ return r.json(); })
      .then(function(cart){
        var c = document.getElementById('sg-cart-count');
        if (c) c.textContent = cart.item_count;
      }).catch(function(){});
  });
</script>

{% schema %}
{
  "name": "Nav",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "text", "id": "wordmark", "label": "Wordmark", "default": "StompGuard" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Pedal Protection Systems" },
    { "type": "page", "id": "contact_page", "label": "Contact Page (optional)" }
  ],
  "presets": [ { "name": "Nav" } ]
}
{% endschema %}
