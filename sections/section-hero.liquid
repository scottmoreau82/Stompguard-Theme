{% comment %} StompGuard — Hero Section + Status Bar {% endcomment %}

<style>
  #sg-hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 60px;
    position: relative;
    overflow: hidden;
  }
  #sg-hero::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--chrome-lo), var(--red), var(--chrome-lo), transparent);
    transform: skewX(-4deg) translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    will-change: transform;
    z-index: 10;
  }
  #sg-hero .hero-left { position: relative; overflow: hidden; background: var(--black); }
  #sg-hero .hero-left-img {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.5;
    filter: grayscale(80%) contrast(1.2);
    mix-blend-mode: luminosity;
  }
  #sg-hero .hero-left-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(139,0,0,0.15) 0%, transparent 60%), linear-gradient(to right, transparent 60%, var(--black) 100%);
  }
  #sg-hero .hero-left-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem;
    z-index: 2;
  }
  #sg-hero .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #sg-hero .hero-eyebrow::before { content: ''; display: block; width: 30px; height: 1px; background: var(--red); }
  #sg-hero .hero-eyebrow::after { content: '\25A0'; font-size: 0.6rem; color: var(--red); }
  #sg-hero .hero-title {
    font-family: var(--font-head);
    font-size: clamp(5rem, 9vw, 8rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--chrome-hi);
    margin-bottom: 2rem;
    text-shadow: 0 0 60px rgba(200,200,200,0.1);
  }
  #sg-hero .hero-title .line-chrome { -webkit-text-stroke: 1px var(--chrome-lo); color: transparent; display: block; }
  #sg-hero .hero-title .line-red { color: var(--red); display: block; }
  #sg-hero .hero-title .line-solid { display: block; }
  #sg-hero .hero-spec {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 360px;
    border-left: 2px solid var(--gunmetal);
    padding-left: 1rem;
  }
  #sg-hero .hero-spec strong { color: var(--chrome-lo); display: block; margin-bottom: 4px; }
  #sg-hero .hero-ctas { display: flex; gap: 1rem; align-items: center; }
  #sg-hero .btn-deploy {
    background: var(--red);
    color: var(--chrome-hi);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 14px 28px;
    text-decoration: none;
    border: 1px solid var(--red-hi);
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  #sg-hero .btn-deploy:hover { background: var(--red-hi); transform: translateY(-2px); }
  #sg-hero .hero-right {
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    position: relative;
  }
  #sg-hero .hero-right::before, #sg-hero .hero-right::after {
    content: '';
    position: absolute;
    width: 40px; height: 40px;
    border-color: var(--chrome-lo);
    border-style: solid;
    opacity: 0.4;
  }
  #sg-hero .hero-right::before { top: 2.5rem; left: 3rem; border-width: 2px 0 0 2px; }
  #sg-hero .hero-right::after { bottom: 2rem; right: 2rem; border-width: 0 2px 2px 0; }
  #sg-hero .hero-product {
    width: 100%;
    max-width: 420px;
    background: var(--surface2);
    border: 1px solid rgba(200,200,200,0.08);
    position: relative;
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
    cursor: pointer;
  }
  #sg-hero .hero-product::before {
    content: 'QC-001';
    position: absolute;
    top: 12px; left: 16px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--chrome-lo);
    z-index: 3;
    opacity: 0.6;
  }
  #sg-hero .hero-product-badge {
    position: absolute;
    top: 0; right: 20px;
    background: var(--red);
    color: var(--chrome-hi);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 5px 12px;
    z-index: 3;
  }
  #sg-hero .hero-product-img { width: 100%; aspect-ratio: 1; overflow: hidden; background: var(--black); position: relative; }
  #sg-hero .hero-product-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.85;
    filter: contrast(1.1) saturate(0.8);
    transition: transform 0.5s ease;
  }
  #sg-hero .hero-product:hover .hero-product-img img { transform: scale(1.03); }
  #sg-hero .hero-product-nav {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 8px;
    background: linear-gradient(transparent, rgba(8,8,8,0.8));
    z-index: 4;
  }
  #sg-hero .hero-product-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--chrome-lo);
    opacity: 0.4;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
    padding: 0;
  }
  #sg-hero .hero-product-dot.active { background: var(--red); opacity: 1; width: 18px; border-radius: 3px; }
  #sg-hero .hero-product-cycle-label {
    position: absolute;
    top: 10px; right: 12px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--chrome-lo);
    opacity: 0.5;
    text-transform: uppercase;
    z-index: 4;
  }
  #sg-hero .hero-product-info { padding: 1.2rem 1.5rem; border-top: 1px solid rgba(200,200,200,0.06); }
  #sg-hero .hero-product-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    color: var(--chrome-lo);
    text-transform: uppercase;
    margin-bottom: 4px;
    opacity: 0.7;
  }
  #sg-hero .hero-product-name {
    font-family: var(--font-head);
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--chrome-hi);
    line-height: 1.2;
    margin-bottom: 0.6rem;
  }
  #sg-hero .hero-product-price { font-family: var(--font-mono); font-size: 1.4rem; color: var(--chrome); letter-spacing: 0.05em; }
  #sg-hero .hero-product-price span { font-size: 0.76rem; color: var(--muted); margin-right: 4px; letter-spacing: 0.2em; }
  @keyframes sg-fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  #sg-hero .hero-eyebrow { animation: sg-fadeUp 0.5s 0.1s both; }
  #sg-hero .hero-title   { animation: sg-fadeUp 0.5s 0.25s both; }
  #sg-hero .hero-spec    { animation: sg-fadeUp 0.5s 0.4s both; }
  #sg-hero .hero-ctas    { animation: sg-fadeUp 0.5s 0.55s both; }
  #sg-status-bar {
    background: var(--surface2);
    border-top: 1px solid rgba(200,200,200,0.05);
    border-bottom: 1px solid rgba(200,200,200,0.05);
    display: flex;
    overflow: hidden;
  }
  #sg-status-bar .status-ticker { display: flex; animation: sg-ticker 35s linear infinite; white-space: nowrap; }
  @keyframes sg-ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  #sg-status-bar .status-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 8px 2rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--chrome-lo);
    flex-shrink: 0;
  }
  #sg-status-bar .status-sep { color: var(--red); font-size: 0.68rem; }
  @media (max-width: 768px) {
    #sg-hero { grid-template-columns: 1fr; }
    #sg-hero::after { display: none; }
    #sg-hero .hero-left { min-height: 60vh; }
    #sg-hero .hero-left-content { padding: 2rem; }
  }
</style>

<section id="sg-hero">
  <div class="hero-left">
    {% if section.settings.hero_image != blank %}
      <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="{{ section.settings.hero_image_alt | escape }}" class="hero-left-img"/>
    {% endif %}
    <div class="hero-left-overlay"></div>
    <div class="hero-left-content">
      <div class="hero-eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="hero-title">
        <span class="line-chrome">{{ section.settings.title_line1 }}</span>
        <span class="line-solid">{{ section.settings.title_line2 }}</span>
        <span class="line-red">{{ section.settings.title_line3 }}</span>
      </h1>
      <div class="hero-spec">
        <strong>{{ section.settings.spec_label }}</strong>
        {{ section.settings.spec_body }}
      </div>
      <div class="hero-ctas">
        <a href="#sg-products-section" class="btn-deploy">{{ section.settings.cta_label }} &rarr;</a>
      </div>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-product" id="sg-hero-product-card" onclick="sgHeroProductClick()">
      <div class="hero-product-badge" id="sg-hero-badge"></div>
      <div class="hero-product-img">
        <div class="hero-product-cycle-label">Click to view</div>
        <img id="sg-hero-product-img" src="" alt="StompGuard product"/>
        <div class="hero-product-nav" id="sg-hero-dots"></div>
      </div>
      <div class="hero-product-info">
        <div class="hero-product-label">Product</div>
        <div class="hero-product-name" id="sg-hero-product-name"></div>
        <div class="hero-product-price"><span>MSRP</span><span id="sg-hero-product-price"></span></div>
      </div>
    </div>
  </div>
</section>

<div id="sg-status-bar">
  <div class="status-ticker">
    {%- assign ticker_items = section.settings.ticker_text | split: '|' -%}
    {%- for item in ticker_items -%}
      <div class="status-item">{{ item | strip }} <span class="status-sep">&rarr;</span></div>
    {%- endfor -%}
    {%- for item in ticker_items -%}
      <div class="status-item">{{ item | strip }} <span class="status-sep">&rarr;</span></div>
    {%- endfor -%}
  </div>
</div>

<script>
  var SG_HERO_PRODUCTS = [
    {%- for product in collections[section.settings.collection].products limit: 6 -%}
      {%- assign badge = '' -%}
      {%- if product.tags contains 'best-seller' -%}{%- assign badge = 'Best Seller' -%}{%- endif -%}
      {%- if product.tags contains 'new' -%}{%- assign badge = 'New' -%}{%- endif -%}
      {
        url: {{ product.url | json }},
        badge: {{ badge | json }},
        name: {{ product.title | json }},
        price: {{ product.price | money | json }},
        img: {{ product.featured_image | image_url: width: 600 | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ];

  var sgHeroIndex = 0;
  var sgHeroCycleTimer = null;

  function sgRenderHeroDots() {
    var dotsEl = document.getElementById('sg-hero-dots');
    if (!dotsEl) return;
    dotsEl.innerHTML = SG_HERO_PRODUCTS.map(function(_, i) {
      return '<button class="hero-product-dot ' + (i === sgHeroIndex ? 'active' : '') + '" onclick="event.stopPropagation(); sgSetHeroProduct(' + i + ')"></button>';
    }).join('');
  }

  function sgSetHeroProduct(idx) {
    if (!SG_HERO_PRODUCTS.length) return;
    sgHeroIndex = idx;
    var hp = SG_HERO_PRODUCTS[idx];
    var imgEl = document.getElementById('sg-hero-product-img');
    imgEl.style.opacity = '0';
    imgEl.style.transition = 'opacity 0.3s';
    setTimeout(function() {
      imgEl.src = hp.img;
      imgEl.alt = hp.name;
      imgEl.style.opacity = '1';
    }, 300);
    document.getElementById('sg-hero-product-name').textContent = hp.name;
    document.getElementById('sg-hero-product-price').textContent = hp.price;
    var badge = document.getElementById('sg-hero-badge');
    badge.textContent = hp.badge;
    badge.style.display = hp.badge ? 'block' : 'none';
    sgRenderHeroDots();
    sgResetHeroCycle();
  }

  function sgHeroProductClick() {
    if (SG_HERO_PRODUCTS.length) window.location.href = SG_HERO_PRODUCTS[sgHeroIndex].url;
  }

  function sgResetHeroCycle() {
    if (sgHeroCycleTimer) clearInterval(sgHeroCycleTimer);
    sgHeroCycleTimer = setInterval(function() {
      sgHeroIndex = (sgHeroIndex + 1) % SG_HERO_PRODUCTS.length;
      sgSetHeroProduct(sgHeroIndex);
    }, 10000);
  }

  document.addEventListener('DOMContentLoaded', function() {
    if (SG_HERO_PRODUCTS.length) { sgSetHeroProduct(0); }
  });
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Premium Pedal Protection" },
    { "type": "text", "id": "title_line1", "label": "Title Line 1 (outline)", "default": "Protect" },
    { "type": "text", "id": "title_line2", "label": "Title Line 2 (solid)", "default": "Your" },
    { "type": "text", "id": "title_line3", "label": "Title Line 3 (red)", "default": "Signal." },
    { "type": "text", "id": "spec_label", "label": "Spec Label", "default": "WHAT IT DOES" },
    { "type": "textarea", "id": "spec_body", "label": "Spec Body", "default": "Precision-cut acrylic protectors for your most valuable gear. Engineered for gigging musicians who protect their gear on stage and in the studio." },
    { "type": "text", "id": "cta_label", "label": "CTA Button Label", "default": "Shop Now" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero Background Image" },
    { "type": "text", "id": "hero_image_alt", "label": "Hero Image Alt Text", "default": "StompGuard on stage" },
    { "type": "collection", "id": "collection", "label": "Hero Product Collection (cycles through products)" },
    { "type": "textarea", "id": "ticker_text", "label": "Status Bar Items (separate with |)", "default": "US Based Operations|Premium Acrylic Construction|Precision Laser Cut|Rapid Order Fulfillment|Neural DSP Specialists|Gig-Ready Protection" }
  ],
  "presets": [ { "name": "Hero" } ]
}
{% endschema %}
