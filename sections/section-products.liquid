{% comment %} StompGuard — Products Section {% endcomment %}

<style>
  #sg-products-section {
    background: var(--black);
    border-top: 1px solid rgba(200,200,200,0.04);
    padding: 7rem 5rem;
  }

  #sg-products-section .products-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  #sg-products-section .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #sg-products-section .section-eyebrow::before {
    content: '//';
    color: var(--chrome-lo);
  }

  #sg-products-section .section-title {
    font-family: var(--font-head);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--chrome-hi);
    line-height: 0.95;
  }

  #sg-products-section .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  #sg-products-section .product-card {
    background: var(--surface);
    position: relative;
    cursor: pointer;
    transition: transform 0.3s ease;
    border: 1px solid rgba(200,200,200,0.05);
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  }

  #sg-products-section .product-card:hover { transform: translateY(-4px); border-color: rgba(200,200,200,0.15); }

  #sg-products-section .product-card-img {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--surface2);
    position: relative;
    min-height: 160px;
  }

  #sg-products-section .product-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.8;
    filter: contrast(1.1) saturate(0.7);
    transition: transform 0.5s ease, opacity 0.3s;
  }

  #sg-products-section .product-card:hover .product-card-img img { transform: scale(1.05); opacity: 1; }

  #sg-products-section .product-card-badge {
    position: absolute;
    top: 0; right: 0;
    background: var(--red);
    color: var(--chrome-hi);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 10px;
    z-index: 2;
  }

  #sg-products-section .product-card-body {
    padding: 1.2rem;
    border-top: 1px solid rgba(200,200,200,0.05);
  }

  #sg-products-section .product-card-unit {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  #sg-products-section .product-card-name {
    font-family: var(--font-head);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--chrome-hi);
    line-height: 1.2;
    margin-bottom: 0.8rem;
  }

  #sg-products-section .product-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #sg-products-section .product-card-price {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--chrome);
    letter-spacing: 0.05em;
  }

  #sg-products-section .add-btn {
    background: transparent;
    border: 1px solid var(--gunmetal);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 12px;
    cursor: pointer;
    transition: all 0.2s;
    clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
    text-decoration: none;
    display: inline-block;
  }

  #sg-products-section .add-btn:hover { background: var(--red); border-color: var(--red); color: var(--chrome-hi); }

  @media (max-width: 1024px) {
    #sg-products-section .products-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    #sg-products-section { padding: 4rem 1.5rem; }
    #sg-products-section .products-grid { grid-template-columns: 1fr; }
  }
</style>

<section id="sg-products-section">
  <div class="products-header">
    <div>
      <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>
  </div>

  <div class="products-grid" id="sg-products">
    {%- for product in collections[section.settings.collection].products -%}
      {%- assign badge = '' -%}
      {%- if product.tags contains 'best-seller' -%}{%- assign badge = 'Best Seller' -%}{%- endif -%}
      {%- if product.tags contains 'new' -%}{%- assign badge = 'New' -%}{%- endif -%}

      <div class="product-card" onclick="window.location.href='{{ product.url }}'">
        <div class="product-card-img">
          <img
            src="{{ product.featured_image | img_url: '500x' }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
          />
          {%- if badge != '' -%}
            <div class="product-card-badge">{{ badge }}</div>
          {%- endif -%}
        </div>
        <div class="product-card-body">
          <div class="product-card-unit">{{ product.metafields.custom.sku | default: product.variants.first.sku }}</div>
          <div class="product-card-name">{{ product.title }}</div>
          <div class="product-card-footer">
            <span class="product-card-price">{{ product.price | money }}</span>
            <a
              class="add-btn"
              href="#"
              onclick="sgAddToCart(event, '{{ product.variants.first.id }}', {{ product.price }}, '{{ product.title | escape }}')"
            >Add to Cart</a>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  function sgAddToCart(event, variantId, price, name) {
    event.preventDefault();
    event.stopPropagation();

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      // Update cart count
      return fetch('/cart.js');
    })
    .then(function(r) { return r.json(); })
    .then(function(cart) {
      var count = document.getElementById('sg-cart-count');
      if (count) count.textContent = cart.item_count;
      // Open cart drawer
      var overlay = document.getElementById('sg-cart-overlay');
      if (overlay) overlay.classList.add('open');
      sgRefreshCartDrawer();
    })
    .catch(function(err) { console.error('Add to cart error:', err); });
  }

  function sgRefreshCartDrawer() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var count = document.getElementById('sg-cart-count');
        if (count) count.textContent = cart.item_count;
        // Trigger cart drawer refresh if it exists
        if (typeof sgRenderCart === 'function') sgRenderCart(cart);
      });
  }
</script>

{% schema %}
{
  "name": "Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Product Catalog"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Protective Covers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Product Collection"
    }
  ],
  "presets": [
    {
      "name": "Products"
    }
  ]
}
{% endschema %}
